# ── LLM Provider ──
# Which API protocol to use: "openai", "anthropic", or "deepseek"
LLM_PROVIDER=deepseek

# DeepSeek API key (same key works for both OpenAI and Anthropic protocols)
LLM_API_KEY=sk-your-key-here

# Optional overrides (defaults shown per provider):
#   openai    → https://api.openai.com/v1
#   anthropic → https://api.anthropic.com/v1
#   deepseek  → https://api.deepseek.com
LLM_BASE_URL=
LLM_MODEL=deepseek-v4-flash

# ── Database ──
# SQLite database file path (default: data/skill-agent.db)
DATABASE_PATH=
